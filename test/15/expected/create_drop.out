SELECT emaj.emaj_comment_group('unknownGroup', NULL);
ERROR:  _check_group_names: The group "unknownGroup" does not exist.
-- Should be OK.
SELECT emaj.emaj_comment_group('myGroup1', 'a first comment for group #1');
