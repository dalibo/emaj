-----------------------------------
-- emaj_remove_table.
-----------------------------------
-- Error cases.
-- Missing table.
SELECT emaj.emaj_remove_table('dummySchema', 'mytbl1');
WARNING:  _check_schema: The schema "dummySchema" does not exist.
ERROR:  _check_tblseqs_array: In schema "dummySchema", some tables (mytbl1) do not currently belong to any table group.
SELECT emaj.emaj_remove_table('myschema1', 'dummyTable');
WARNING:  _check_tblseqs_array: In schema "myschema1", some tables ("dummyTable") do not exist.
ERROR:  _check_tblseqs_array: In schema "myschema1", some tables ("dummyTable") do not currently belong to any table group.
-- Table not in a group.
SELECT emaj.emaj_remove_table('myschema6', 'table_with_50_characters_long_name_____0_________0');
ERROR:  _check_tblseqs_array: In schema "myschema6", some tables (table_with_50_characters_long_name_____0_________0) do not currently belong to any table group.
-- Bad relation kind.
SELECT emaj.emaj_remove_table('myschema1', 'mytbl2b_col20_seq');
WARNING:  _check_tblseqs_array: In schema "myschema1", some tables (mytbl2b_col20_seq) do not exist.
ERROR:  _check_tblseqs_array: In schema "myschema1", some tables (mytbl2b_col20_seq) do not currently belong to any table group.
-- Bad mark.
SELECT emaj.emaj_remove_table('myschema1', 'mytbl1', 'EMAJ_LAST_MARK');
ERROR:  _check_new_mark: "EMAJ_LAST_MARK" is not an allowed name for a new mark.
-- Ok.
SELECT emaj.emaj_remove_table('myschema1', 'mytbl1');
 emaj_remove_table 
-------------------
                 1
(1 row)

