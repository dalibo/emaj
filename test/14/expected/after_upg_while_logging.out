SELECT regexp_replace(scr_sql, '^-- SQL script generated by E-Maj at .*', '-- SQL script generated by E-Maj at %') FROM emaj_sql_script;
                                                 regexp_replace                                                 
----------------------------------------------------------------------------------------------------------------
 -- SQL script generated by E-Maj at %
 --    for tables group(s): myGroup1
 --    processing logs between mark "M1" and the current state
 --    only for the following tables/sequences: myschema1.mytbl1,myschema1.mytbl2,myschema1.mytbl4
 SET datestyle = 'ISO, YMD';
 BEGIN TRANSACTION;
 INSERT INTO myschema1.mytbl1 VALUES (1, 'ABC', E'\\x0c');
 INSERT INTO myschema1.mytbl1 VALUES (2, 'ABC', E'\\x0c');
 INSERT INTO myschema1.mytbl1 VALUES (3, 'ABC', E'\\x0c');
 INSERT INTO myschema1.mytbl1 VALUES (4, 'ABC', E'\\x0c');
 INSERT INTO myschema1.mytbl1 VALUES (5, 'ABC', E'\\x0c');
 INSERT INTO myschema1.mytbl1 VALUES (6, 'ABC', E'\\x0c');
 INSERT INTO myschema1.mytbl1 VALUES (7, 'ABC', E'\\x0c');
 INSERT INTO myschema1.mytbl1 VALUES (8, 'ABC', E'\\x0c');
 INSERT INTO myschema1.mytbl1 VALUES (9, 'ABC', E'\\x0c');
 INSERT INTO myschema1.mytbl1 VALUES (10, 'ABC', E'\\x0c');
 INSERT INTO myschema1.mytbl1 VALUES (11, 'ABC', E'\\x0c');
 UPDATE ONLY myschema1.mytbl1 SET col11 = 1, col12 = 'ABC', col13 = E'\\x1c' WHERE col11 = 1 AND col12 = 'ABC';
 UPDATE ONLY myschema1.mytbl1 SET col11 = 2, col12 = 'ABC', col13 = E'\\x1c' WHERE col11 = 2 AND col12 = 'ABC';
 UPDATE ONLY myschema1.mytbl1 SET col11 = 3, col12 = 'ABC', col13 = E'\\x1c' WHERE col11 = 3 AND col12 = 'ABC';
 INSERT INTO myschema1.mytbl2 VALUES (1, 'ABC', '2010-12-31');
 DELETE FROM ONLY myschema1.mytbl1 WHERE col11 = 11 AND col12 = 'ABC';
 INSERT INTO myschema1.mytbl2 VALUES (2, 'DEF', NULL);
 INSERT INTO myschema1.mytbl1 VALUES (100, 'DEF', E'\\x00');
 INSERT INTO myschema1.mytbl1 VALUES (101, 'DEF', E'\\x00');
 INSERT INTO myschema1.mytbl1 VALUES (102, 'DEF', E'\\x00');
 INSERT INTO myschema1.mytbl1 VALUES (103, 'DEF', E'\\x00');
 INSERT INTO myschema1.mytbl1 VALUES (104, 'DEF', E'\\x00');
 INSERT INTO myschema1.mytbl1 VALUES (105, 'DEF', E'\\x00');
 INSERT INTO myschema1.mytbl1 VALUES (106, 'DEF', E'\\x00');
 INSERT INTO myschema1.mytbl1 VALUES (107, 'DEF', E'\\x00');
 INSERT INTO myschema1.mytbl1 VALUES (108, 'DEF', E'\\x00');
 INSERT INTO myschema1.mytbl1 VALUES (109, 'DEF', E'\\x00');
 INSERT INTO myschema1.mytbl1 VALUES (110, 'DEF', E'\\x00');
 INSERT INTO myschema1.mytbl2 VALUES (3, 'GHI', '2010-01-02');
 DELETE FROM ONLY myschema1.mytbl1 WHERE col11 = 1 AND col12 = 'ABC';
 INSERT INTO myschema1.mytbl1 VALUES (1, E'Step  6', E'\\x01');
 INSERT INTO myschema1.mytbl4 VALUES (11, NULL, 1, 1, E'Step     6');
 INSERT INTO myschema1.mytbl4 VALUES (12, NULL, 1, 1, E'Step     6');
 DELETE FROM ONLY myschema1.mytbl4 WHERE col41 = 11 AND col43 = 1;
 DELETE FROM ONLY myschema1.mytbl4 WHERE col41 = 12 AND col43 = 1;
 DELETE FROM ONLY myschema1.mytbl1 WHERE col11 = 1 AND col12 = E'Step    6';
 COMMIT;
 RESET datestyle;
