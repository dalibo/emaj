-----------------------------
-- Step 5 : alter group myGroup1 by removing a table.
-----------------------------
DELETE FROM emaj.emaj_group_def WHERE grpdef_schema = 'myschema1' AND grpdef_tblseq = 'myTbl3';
SELECT emaj.emaj_alter_group('myGroup1');
 emaj_alter_group 
------------------
                5
(1 row)

